{
  "name": "stale-buffer-guard",
  "displayName": "Stale Buffer Guard",
  "description": "Stops stale VS Code editor tabs after disk changes and warns when unsaved edits are based on old contents.",
  "version": "0.2.0",
  "publisher": "omry",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/omry/stale-buffer-guard.git"
  },
  "bugs": {
    "url": "https://github.com/omry/stale-buffer-guard/issues"
  },
  "homepage": "https://github.com/omry/stale-buffer-guard#readme",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "scripts": {
    "check": "node --check extension.js && node --check stale-state.js && npm test",
    "test": "node test/*.test.js"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:staleBufferGuard.checkActiveEditor",
    "onCommand:staleBufferGuard.refreshBaseline",
    "onCommand:staleBufferGuard.reloadFromDisk",
    "onCommand:staleBufferGuard.dismissEditorWarning",
    "onCommand:staleBufferGuard.showActions",
    "onCommand:staleBufferGuard.showStatus"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "staleBufferGuard.checkActiveEditor",
        "title": "Stale Buffer Guard: Check Active Editor",
        "icon": "$(sync)"
      },
      {
        "command": "staleBufferGuard.refreshBaseline",
        "title": "Stale Buffer Guard: Keep Editor Buffer",
        "icon": "$(check)"
      },
      {
        "command": "staleBufferGuard.reloadFromDisk",
        "title": "Stale Buffer Guard: Discard Buffer and Reload",
        "icon": "$(discard)"
      },
      {
        "command": "staleBufferGuard.dismissEditorWarning",
        "title": "Stale Buffer Guard: Hide Editor Warning",
        "icon": "$(eye-closed)"
      },
      {
        "command": "staleBufferGuard.showActions",
        "title": "Stale Buffer Guard: Show Actions",
        "icon": "$(warning)"
      },
      {
        "command": "staleBufferGuard.showStatus",
        "title": "Stale Buffer Guard: Explain Stale Warning",
        "icon": "$(warning)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "staleBufferGuard.showStatus",
          "when": "staleBufferGuard.activeEditorWarningVisible",
          "group": "navigation@1"
        },
        {
          "command": "staleBufferGuard.checkActiveEditor",
          "when": "staleBufferGuard.activeEditorWarningVisible",
          "group": "navigation@2"
        },
        {
          "command": "staleBufferGuard.reloadFromDisk",
          "when": "staleBufferGuard.activeEditorWarningVisible",
          "group": "navigation@3"
        },
        {
          "command": "staleBufferGuard.refreshBaseline",
          "when": "staleBufferGuard.activeEditorWarningVisible",
          "group": "navigation@4"
        },
        {
          "command": "staleBufferGuard.dismissEditorWarning",
          "when": "staleBufferGuard.activeEditorWarningVisible",
          "group": "navigation@5"
        }
      ]
    },
    "configuration": {
      "title": "Stale Buffer Guard",
      "properties": {
        "staleBufferGuard.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable stale open-buffer detection."
        },
        "staleBufferGuard.pollIntervalMs": {
          "type": "number",
          "default": 2000,
          "minimum": 250,
          "description": "How often to re-check open file editors for changed files on disk."
        }
      }
    }
  }
}
